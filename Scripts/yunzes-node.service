[Unit]
Description=yunzes-node Service
After=network.target nss-lookup.target
Wants=network.target

[Service]
User=root
Group=root
Type=simple
LimitAS=infinity
LimitRSS=infinity
LimitCORE=infinity
LimitNOFILE=999999
WorkingDirectory=/usr/local/yunzes-node/
ExecStart=/usr/local/yunzes-node/yunzes-node server -c /etc/yunzes-node/config.json
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target